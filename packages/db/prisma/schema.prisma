generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  VENDOR
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DealCategory {
  FOOD
  DRINKS
  SUBSCRIPTIONS
  TRANSPORT
  SHOPPING
  LIFESTYLE
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole @default(STUDENT)
  fullName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student  Student?
  vendor   Vendor?
  payments Payment[]

  @@index([email])
  @@index([phone])
}

model Student {
  id                  String             @id @default(cuid())
  userId              String             @unique
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  university          String
  studentIdImageUrl   String?
  schoolEmail         String?
  schoolEmailVerified Boolean            @default(false)
  verificationStatus  VerificationStatus @default(PENDING)
  verifiedAt          DateTime?
  rejectionReason     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  vouchers      Voucher[]
  loyaltyCards  LoyaltyCard[]

  @@index([verificationStatus])
  @@index([university])
}

model Vendor {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String
  businessAddress String
  businessPhone   String
  logoUrl         String?
  isActive        Boolean  @default(true)
  opensAt         String   @default("08:00") // HH:mm in WAT
  closesAt        String   @default("21:00") // HH:mm in WAT
  dailyCode       String?
  dailyCodeDate   DateTime?
  commissionRate  Float    @default(0.10)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deals        Deal[]
  payouts      Payout[]
  loyaltyCards LoyaltyCard[]

  @@index([isActive])
}

model Deal {
  id            String       @id @default(cuid())
  vendorId      String
  vendor        Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  title         String
  description   String
  category      DealCategory
  imageUrl      String?
  originalPrice Int
  studentPrice  Int
  totalQuantity Int
  remainingQty  Int
  maxPerUser    Int          @default(1)
  startsAt      DateTime
  expiresAt     DateTime
  isActive      Boolean      @default(true)
  isFeatured    Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  vouchers Voucher[]
  payments Payment[]

  @@index([category, isActive])
  @@index([vendorId])
  @@index([isActive, expiresAt])
  @@index([isFeatured, isActive])
}

model Voucher {
  id             String        @id @default(cuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  dealId         String
  deal           Deal          @relation(fields: [dealId], references: [id])
  paymentId      String        @unique
  payment        Payment       @relation(fields: [paymentId], references: [id])
  code           String        @unique
  qrData         String        @unique
  status         VoucherStatus @default(ACTIVE)
  expiresAt      DateTime
  redeemedAt     DateTime?
  redeemedByCode Boolean       @default(false)
  createdAt      DateTime      @default(now())

  @@index([studentId, status])
  @@index([code])
  @@index([qrData])
  @@index([status, expiresAt])
}

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  dealId             String
  deal               Deal          @relation(fields: [dealId], references: [id])
  amount             Int
  commission         Int
  vendorAmount       Int
  paystackReference  String        @unique
  paystackAccessCode String?
  status             PaymentStatus @default(PENDING)
  paidAt             DateTime?
  metadata           Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  voucher Voucher?

  @@index([userId])
  @@index([paystackReference])
  @@index([status])
}

model Payout {
  id                   String   @id @default(cuid())
  vendorId             String
  vendor               Vendor   @relation(fields: [vendorId], references: [id])
  amount               Int
  periodStart          DateTime
  periodEnd            DateTime
  voucherCount         Int
  status               String   @default("PENDING")
  paystackTransferCode String?
  paidAt               DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([vendorId, status])
}

model OTP {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}

model LoyaltyCard {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  vendorId    String
  vendor      Vendor   @relation(fields: [vendorId], references: [id])
  stamps      Int      @default(0)  // current stamps collected
  target      Int      @default(5)  // stamps needed for free deal
  rewardsUsed Int      @default(0)  // how many free deals claimed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([studentId, vendorId])
  @@index([studentId])
  @@index([vendorId])
}
